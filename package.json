  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "tailwindcss": "^4.1.17",
    "@tailwindcss/cli": "^4.1.17",
    "htmlhint": "^1.7.1",
    "http-server": "^14.1.1"
  }
}
