{
  "buildCommand": "node scripts/generate-config.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login",     "destination": "/login.html" },
    { "source": "/signup",    "destination": "/signup.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/workspace", "destination": "/workspace.html" }
  ]
}
